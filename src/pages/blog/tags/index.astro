---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Content
import { getCollection } from "astro:content";
const allPosts = await getCollection("posts");
// Tags
const tags = [...new Set(allPosts.map((post) => post.data.tags).flat())];
const pageTitle = "Tag Index";
---

<BaseLayout pageTitle={pageTitle}>
  <section>
    <Wrapper variant="standard">
      <div data-aos="fade-down" data-aos-duration="3000">
        <h1 class="text-4xl lg:text-5xl text-white font-display">
          AwakeMode posts grouped by topic
        </h1>
      </div>
      <ol
        role="list"
        class="flex flex-col mt-12 divide-y divide-base-800 border-y border-base-800"
      >
        {
          tags.map((tag) => (
            <li class="py-4">
              <Text
                tag="a"
                variant="texrtBase"
                class=" text-base-300 flex items-center capitalize justify-between hover:text-accent-400"
                href={`/blog/tags/${tag}`}
              >
                {tag}
                <span>
                  <svg
                    width="15"
                    height="15"
                    viewBox="0 0 15 15"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      d="M8.14645 3.14645C8.34171 2.95118 8.65829 2.95118 8.85355 3.14645L12.8536 7.14645C13.0488 7.34171 13.0488 7.65829 12.8536 7.85355L8.85355 11.8536C8.65829 12.0488 8.34171 12.0488 8.14645 11.8536C7.95118 11.6583 7.95118 11.3417 8.14645 11.1464L11.2929 8H2.5C2.22386 8 2 7.77614 2 7.5C2 7.22386 2.22386 7 2.5 7H11.2929L8.14645 3.85355C7.95118 3.65829 7.95118 3.34171 8.14645 3.14645Z"
                      fill="currentColor"
                      fill-rule="evenodd"
                      clip-rule="evenodd"
                    />
                  </svg>
                </span>
              </Text>
            </li>
          ))
        }
      </ol>
    </Wrapper>
  </section>
</BaseLayout>
