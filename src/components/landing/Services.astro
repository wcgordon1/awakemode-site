---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Data
const items = [
  "Wake lock sessions",
  "Countdown timers",
  "Indefinite mode",
  "Session presets",
  "Auto-reacquire",
  "Battery-aware states",
  "Capability detection",
  "Chrome extension mode",
  "System/display keep-awake",
  "Status history",
  "Keyboard shortcuts",
  "Simple controls",
];
// Content
import ServicesCard from "@/components/services/ServicesCard.astro";
const allServices = await getCollection("services");
import { getCollection } from "astro:content";
---

<section id="services" class="scroll-mt-24">
  <Wrapper variant="standard" class="py-24">
    <div data-aos="fade-up" data-aos-duration="2000">
      <Text tag="h3" variant="displayMD" class="text-white font-display">
        AwakeMode features for real workflows<span class="md:block text-base-400">
          built for people who cannot afford sleep interruptions.</span
        >
      </Text>
      <div class="flex mt-12">
        <Button href="/services/web-dev" size="lg" variant="muted"
          >Explore all features</Button
        >
      </div>
    </div>
    <ul
      class="grid grid-cols-2 gap-4 py-6 mt-12 sm:grid-cols-2 order-y border-base-800 md:grid-cols-4"
    >
      {
        items.map((item) => (
          <li>
            <Text
              tag="p"
              variant="textBase"
              class="flex items-center gap-2 text-base-300"
            >
              <svg
                width="15"
                height="15"
                viewBox="0 0 15 15"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M11.4669 3.72684C11.7558 3.91574 11.8369 4.30308 11.648 4.59198L7.39799 11.092C7.29783 11.2452 7.13556 11.3467 6.95402 11.3699C6.77247 11.3931 6.58989 11.3355 6.45446 11.2124L3.70446 8.71241C3.44905 8.48022 3.43023 8.08494 3.66242 7.82953C3.89461 7.57412 4.28989 7.55529 4.5453 7.78749L6.75292 9.79441L10.6018 3.90792C10.7907 3.61902 11.178 3.53795 11.4669 3.72684Z"
                  fill="currentColor"
                  fill-rule="evenodd"
                  clip-rule="evenodd"
                />
              </svg>{" "}
              {item}
            </Text>
          </li>
        ))
      }
    </ul>

    <div
      class="flex flex-col mt-8 divide-y divide-base-800 border-y border-base-800"
    >
      {allServices.map((post) => <ServicesCard post={post} />)}
    </div>
  </Wrapper>
</section>
