---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const features = [
  {
    id: "quickStart",
    title: "One-click start",
    description:
      "Launch a keep-awake session in seconds without opening terminal commands.",
    dataAos: "fade-right",
    iconId: "calculator",
  },
  {
    id: "clearStatus",
    title: "Clear status",
    description:
      "Always know if wake lock is active, blocked, or unavailable in your browser.",
    dataAos: "fade-down",
    iconId: "time",
  },
  {
    id: "timers",
    title: "Flexible timers",
    description:
      "Run indefinite sessions or set countdown presets for predictable shutdown.",
    dataAos: "fade-left",
    iconId: "delivery",
  },
  {
    id: "localSettings",
    title: "Saved preferences",
    description: "Persist default mode, timer, and behavior locally in your browser.",
    dataAos: "fade-right",
    iconId: "store",
  },
  {
    id: "extensionPath",
    title: "Extension path",
    description:
      "Move to the Chrome extension when you need stronger system keep-awake options.",
    dataAos: "fade-up",
    iconId: "pause",
  },
  {
    id: "simpleUi",
    title: "Simple by design",
    description:
      "Focused UI inspired by Amphetamine: minimal clicks and reliable control.",
    dataAos: "fade-left",
    iconId: "satisfied",
  },
];
---

<section class="overflow-hidden relative">
  <Wrapper class="py-12 lg:py-24">
    <div
      class="lg:text-center max-w-3xl lg:mx-auto"
      data-aos="fade-up"
      data-aos-duration="2000"
    >
      <Text tag="h3" variant="displayMD" class="text-white font-display"
        >Why people use AwakeMode</Text
      >
      <Text tag="p" variant="textBase" class="text-base-300 mt-4">
        Browser-native keep-awake control with a clean path to extension-level power.
      </Text>
    </div>
    <div
      class="grid grid-cols-2 gap-6 lg:grid-cols-3 lg:gap-x-6 mt-24 lg:gap-y-24 lg:text-center"
    >
      {
        features.map((feature) => (
          <div class="pb-4 border-b border-base-800">
            <div>
              <div
                data-aos={feature.dataAos}
                data-aos-duration="2000"
                class="flex items-center justify-center size-12 text-accent-300 rounded-xl bg-gradient-to-tr from-base-950 to-base-700 lg:mx-auto border border-base-800 shadow-massive"
              >
                {feature.iconId === "calculator" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="currentColor"
                    viewBox="0 0 32 32"
                    aria-hidden="true"
                    class="size-6"
                  >
                    <path d="M26,4V28H6V4H26m0-2H6A2,2,0,0,0,4,4V28a2,2,0,0,0,2,2H26a2,2,0,0,0,2-2V4A2,2,0,0,0,26,2Z" />
                    <path d="M9 23H11V25H9zM21 23H23V25H21zM9 18H11V20H9zM21 18H23V20H21zM9 13H11V15H9zM15 23H17V25H15zM15 18H17V20H15zM15 13H17V15H15zM21 13H23V15H21zM9 7H23V10H9z" />
                    <title>Timer</title>
                  </svg>
                )}
                {feature.iconId === "time" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="currentColor"
                    viewBox="0 0 32 32"
                    aria-hidden="true"
                    class="size-6"
                  >
                    <path d="M16,30A14,14,0,1,1,30,16,14,14,0,0,1,16,30ZM16,4A12,12,0,1,0,28,16,12,12,0,0,0,16,4Z" />
                    <path d="M20.59 22L15 16.41 15 7 17 7 17 15.58 22 20.59 20.59 22z" />
                    <title>Status</title>
                  </svg>
                )}
                {feature.iconId === "delivery" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="currentColor"
                    viewBox="0 0 32 32"
                    aria-hidden="true"
                    class="size-6"
                  >
                    <path d="M4 16H16V18H4zM2 11H12V13H2z" />
                    <path d="M29.9189,16.6064l-3-7A.9985.9985,0,0,0,26,9H23V7a1,1,0,0,0-1-1H6V8H21V20.5562A3.9924,3.9924,0,0,0,19.1421,23H12.8579a4,4,0,1,0,0,2h6.2842a3.9806,3.9806,0,0,0,7.7158,0H29a1,1,0,0,0,1-1V17A.9965.9965,0,0,0,29.9189,16.6064ZM9,26a2,2,0,1,1,2-2A2.0023,2.0023,0,0,1,9,26ZM23,11h2.3408l2.1431,5H23Zm0,15a2,2,0,1,1,2-2A2.0023,2.0023,0,0,1,23,26Zm5-3H26.8579A3.9954,3.9954,0,0,0,23,20V18h5Z" />
                    <title>Performance</title>
                  </svg>
                )}
                {feature.iconId === "store" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="currentColor"
                    viewBox="0 0 32 32"
                    aria-hidden="true"
                    class="size-6"
                  >
                    <path d="M30,10.68l-2-6A1,1,0,0,0,27,4H5a1,1,0,0,0-1,.68l-2,6A1.19,1.19,0,0,0,2,11v6a1,1,0,0,0,1,1H4V28H6V18h6V28H28V18h1a1,1,0,0,0,1-1V11A1.19,1.19,0,0,0,30,10.68ZM26,26H14V18H26Zm2-10H24V12H22v4H17V12H15v4H10V12H8v4H4V11.16L5.72,6H26.28L28,11.16Z" />
                    <title>Local settings</title>
                  </svg>
                )}
                {feature.iconId === "pause" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="currentColor"
                    viewBox="0 0 32 32"
                    aria-hidden="true"
                    class="size-6"
                  >
                    <path d="M12 8V24H8V8h4m0-2H8A2 2 0 006 8V24a2 2 0 002 2h4a2 2 0 002-2V8a2 2 0 00-2-2zM24 8V24H20V8h4m0-2H20a2 2 0 00-2 2V24a2 2 0 002 2h4a2 2 0 002-2V8a2 2 0 00-2-2z" />
                    <title>Extension</title>
                  </svg>
                )}
                {feature.iconId === "satisfied" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="currentColor"
                    viewBox="0 0 32 32"
                    aria-hidden="true"
                    class="size-6"
                  >
                    <path d="M16,2A14,14,0,1,0,30,16,14,14,0,0,0,16,2Zm0,26A12,12,0,1,1,28,16,12,12,0,0,1,16,28Z" />
                    <path d="M11.5 11A2.5 2.5 0 1014 13.5 2.48 2.48 0 0011.5 11zM20.5 11A2.5 2.5 0 1023 13.5 2.48 2.48 0 0020.5 11zM16 24a8 8 0 006.85-3.89l-1.71-1a6 6 0 01-10.28 0l-1.71 1A8 8 0 0016 24z" />
                    <title>Simple</title>
                  </svg>
                )}
              </div>
              <Text
                tag="h3"
                variant="textLG"
                class="mt-12  font-medium leading-6 text-white"
              >
                {feature.title}
              </Text>
            </div>
            <Text tag="p" variant="textBase" class="mt-4  text-base-400">
              {feature.description}
            </Text>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
