---
import { AstroSeo } from "@astrolib/seo";
---

<AstroSeo
  title="AwakeMode | Keep your computer awake"
  description="AwakeMode keeps your computer awake while browser sessions, downloads, renders, and automations are running."
  canonical="https://awakemode.com"
  openGraph={{
    url: "https://awakemode.com",
    title: "AwakeMode | Keep your computer awake",
    description:
      "Browser-first keep-awake control with a path to extension-level power.",
    images: [
      {
        url: "https://awakemode.com/icon.svg",
        width: 512,
        height: 512,
        alt: "AwakeMode logo",
        type: "image/svg+xml",
      },
    ],
    site_name: "AwakeMode",
    type: "website",
    locale: "en_US",
  }}
  twitter={{
    handle: "@AwakeModeApp",
    site: "@AwakeModeApp",
    cardType: "summary_large_image",
  }}
/>
