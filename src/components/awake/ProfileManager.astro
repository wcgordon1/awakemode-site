<div class="space-y-4 rounded-xl border border-base-700 bg-base-900/70 p-4">
  <div class="flex items-center justify-between">
    <p class="text-xs uppercase tracking-wider text-base-300">Session profiles</p>
    <div class="flex items-center gap-2">
      <p id="awake-profile-count" class="text-xs text-base-500"></p>
      <button
        id="awake-profile-new-shortcut"
        type="button"
        class="inline-flex h-6 w-6 items-center justify-center rounded-full border border-accent-400 bg-base-800 text-sm font-medium text-accent-100 hover:border-accent-300 hover:text-white"
        aria-label="Create new profile"
        title="Create new profile"
      >
        +
      </button>
    </div>
  </div>

  <div class="grid gap-3 sm:grid-cols-2">
    <label class="flex flex-col gap-2">
      <span class="text-xs text-base-400">Select profile</span>
      <div id="awake-profile-select-control" class="relative">
        <input id="awake-profile-select" type="hidden" value="__new" />
        <button
          id="awake-profile-select-trigger"
          type="button"
          role="combobox"
          aria-haspopup="listbox"
          aria-expanded="false"
          aria-controls="awake-profile-select-listbox"
          class="awake-listbox-trigger flex w-full items-center justify-between rounded-lg border border-base-700 bg-base-900 px-3 py-2 text-left text-sm text-white focus:border-accent-300 focus:outline-none focus:ring-1 focus:ring-accent-300"
        >
          <span id="awake-profile-select-label">Create new profile</span>
          <span aria-hidden="true" class="text-base-500">▾</span>
        </button>
        <ul
          id="awake-profile-select-listbox"
          role="listbox"
          tabindex="-1"
          class="absolute z-20 mt-2 hidden max-h-64 w-full overflow-y-auto rounded-lg border border-accent-400/60 bg-base-900/95 p-1 text-sm shadow-big backdrop-blur-md"
        ></ul>
      </div>
    </label>

    <label id="awake-profile-name-field" class="flex flex-col gap-2">
      <span class="text-xs text-base-400">Name</span>
      <input
        id="awake-profile-name"
        type="text"
        maxlength="24"
        placeholder="e.g. Overnight render"
        class="rounded-lg border border-base-700 bg-base-900 px-3 py-2 text-sm text-white placeholder:text-base-500 focus:border-accent-300 focus:ring-accent-300"
      />
    </label>
  </div>

  <div class="grid gap-3 sm:grid-cols-2">
    <label class="flex flex-col gap-2">
      <span class="text-xs text-base-400">Profile mode</span>
      <select
        id="awake-profile-mode"
        class="awake-select rounded-lg border border-base-700 bg-base-900 px-3 py-2 text-sm text-white focus:border-accent-300 focus:ring-accent-300"
      >
        <option value="indefinite">Indefinite</option>
        <option value="timer">Timer</option>
      </select>
    </label>

    <label class="flex flex-col gap-2">
      <span class="text-xs text-base-400">Duration (minutes)</span>
      <input
        id="awake-profile-duration"
        type="number"
        min="1"
        max="1440"
        placeholder="30"
        class="rounded-lg border border-base-700 bg-base-900 px-3 py-2 text-sm text-white placeholder:text-base-500 focus:border-accent-300 focus:ring-accent-300"
      />
    </label>
  </div>

  <div class="grid gap-2 sm:grid-cols-3">
    <button
      id="awake-profile-save"
      type="button"
      class="rounded-lg border border-accent-400 bg-base-800 px-3 py-2 text-sm text-white hover:border-accent-300"
    >
      Save profile
    </button>
    <button
      id="awake-profile-set-default"
      type="button"
      class="rounded-lg border border-base-700 bg-base-900 px-3 py-2 text-sm text-base-200 hover:text-white hover:border-accent-300"
    >
      Set default
    </button>
    <button
      id="awake-profile-delete"
      type="button"
      class="rounded-lg border border-base-700 bg-base-900 px-3 py-2 text-sm text-base-200 hover:text-white hover:border-rose-400"
    >
      Delete
    </button>
  </div>

  <p id="awake-profile-feedback" class="text-xs text-base-400" aria-live="polite"></p>
</div>
