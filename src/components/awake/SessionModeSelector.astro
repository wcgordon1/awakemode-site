<div class="grid grid-cols-2 gap-2" role="radiogroup" aria-label="Session mode">
  <label class="cursor-pointer">
    <input
      class="peer sr-only"
      type="radio"
      name="awake-session-mode"
      value="indefinite"
      checked
    />
    <span
      class="block rounded-lg border border-base-700 px-3 py-2 text-sm text-base-200 transition peer-checked:border-accent-300 peer-checked:text-white peer-checked:bg-base-800"
    >
      Indefinite
    </span>
  </label>

  <label class="cursor-pointer">
    <input
      class="peer sr-only"
      type="radio"
      name="awake-session-mode"
      value="timer"
    />
    <span
      class="block rounded-lg border border-base-700 px-3 py-2 text-sm text-base-200 transition peer-checked:border-accent-300 peer-checked:text-white peer-checked:bg-base-800"
    >
      Timer
    </span>
  </label>
</div>
