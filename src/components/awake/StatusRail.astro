---
import PlatformHint from "@/components/awake/PlatformHint.astro";
import SessionStatusBadge from "@/components/awake/SessionStatusBadge.astro";
---

<div class="space-y-4">
  <SessionStatusBadge />

  <div class="rounded-xl border border-base-700 bg-base-900/80 p-4">
    <p class="text-xs uppercase tracking-wider text-base-400">Reliability</p>
    <p class="mt-3 text-sm text-base-300">
      Lock losses this session:
      <span id="awake-lock-loss-count" class="font-medium text-white">0</span>
    </p>
  </div>

  <div class="rounded-xl border border-base-700 bg-base-900/80 p-4">
    <p class="text-xs uppercase tracking-wider text-base-400">Event log</p>
    <ol id="awake-event-log" class="mt-3 space-y-2 text-xs text-base-300"></ol>
  </div>

  <PlatformHint />
</div>
