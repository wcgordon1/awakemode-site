<div class="space-y-4">
  <div class="rounded-xl border border-base-700 bg-base-900/80 p-4">
    <p class="awake-kicker text-xs uppercase tracking-wider text-base-400">Session reliability</p>
    <p class="mt-1 text-xs text-base-500">
      Wake lock interruptions detected in this tab session.
    </p>
    <p class="mt-3 text-sm text-base-300">
      Lock losses this session:
      <span id="awake-lock-loss-count" class="font-medium text-white">0</span>
    </p>
  </div>

  <div class="rounded-xl border border-base-700 bg-base-900/80 p-4">
    <div class="flex items-start justify-between gap-3">
      <div>
        <p class="awake-kicker text-xs uppercase tracking-wider text-base-400">Event log</p>
        <p class="mt-1 text-xs text-base-500">Recent wake-session events and timing details.</p>
      </div>
      <button
        id="awake-event-log-toggle"
        type="button"
        class="rounded-md border border-base-700 bg-base-900 px-2.5 py-1.5 text-[11px] font-medium uppercase tracking-wider text-base-300 hover:border-accent-300 hover:text-white"
        aria-expanded="false"
        hidden
      >
        Show full log
      </button>
    </div>
    <div class="mt-3 overflow-x-auto">
      <table class="w-full table-fixed border-collapse text-xs text-base-300">
        <thead>
          <tr class="text-[10px] uppercase tracking-wider text-base-500">
            <th class="w-[48%] py-1.5 pr-5 text-left font-medium">Event</th>
            <th class="w-[17%] py-1.5 pr-5 text-left font-medium">Time</th>
            <th class="w-[15%] py-1.5 pr-5 text-left font-medium">Duration</th>
            <th class="w-[20%] py-1.5 text-left font-medium">Detail</th>
          </tr>
        </thead>
        <tbody id="awake-event-log"></tbody>
      </table>
    </div>
  </div>
</div>
