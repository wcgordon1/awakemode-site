<div class="rounded-xl border border-base-700 bg-base-900/80 p-4">
  <div class="flex flex-wrap items-center gap-3">
    <span
      id="awake-status-badge"
      class="inline-flex rounded-full border border-base-700 px-3 py-1 text-xs uppercase tracking-wider text-base-200"
    >
      Released
    </span>
    <span id="awake-timer-remaining" class="text-xs text-accent-300" hidden></span>
  </div>
  <p id="awake-status-detail" class="mt-3 text-sm text-base-300">
    No active wake lock session.
  </p>

  <div id="awake-timer-visual" class="mt-4 space-y-2" hidden>
    <div class="h-1.5 w-full overflow-hidden rounded-full bg-base-800">
      <div
        id="awake-timer-progress-bar"
        class="h-full w-full origin-left rounded-full bg-accent-400 transition-transform duration-500 ease-out"
        style="transform: scaleX(1)"
      ></div>
    </div>
    <p
      id="awake-timer-countdown"
      class="text-base font-medium text-accent-100 sm:text-lg"
      aria-live="polite"
    ></p>
  </div>
</div>
