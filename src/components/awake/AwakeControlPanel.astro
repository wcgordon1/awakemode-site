---
import CapabilityBanner from "@/components/awake/CapabilityBanner.astro";
import CustomTimerInput from "@/components/awake/CustomTimerInput.astro";
import PrimarySessionAction from "@/components/awake/PrimarySessionAction.astro";
import ProfileManager from "@/components/awake/ProfileManager.astro";
import ProfileQuickLaunch from "@/components/awake/ProfileQuickLaunch.astro";
import SessionModeSelector from "@/components/awake/SessionModeSelector.astro";
import SessionStatusBadge from "@/components/awake/SessionStatusBadge.astro";
import ShortcutHints from "@/components/awake/ShortcutHints.astro";
import StatusRail from "@/components/awake/StatusRail.astro";
import TimerPresets from "@/components/awake/TimerPresets.astro";
---

<div id="awake-control-panel" class="mx-auto mt-12 w-full max-w-3xl">
  <div class="awake-shell rounded-3xl border border-base-700 bg-base-950/70 p-6 shadow-massive backdrop-blur-xl">
    <div class="space-y-4 text-left">
      <SessionStatusBadge />

      <div class="rounded-xl border border-base-700 bg-base-900/70 p-4">
        <p class="awake-kicker text-xs uppercase tracking-wider text-base-400">Session mode</p>
        <div class="mt-3">
          <SessionModeSelector />
        </div>

        <div id="awake-timer-controls" class="mt-4 space-y-4">
          <div class="space-y-2">
            <p class="awake-kicker text-xs uppercase tracking-wider text-base-400">Timer presets</p>
            <TimerPresets />
          </div>
          <CustomTimerInput />
        </div>

        <div class="mt-4 grid gap-2 sm:grid-cols-[1fr_auto]">
          <PrimarySessionAction />
          <button
            id="awake-retry-action"
            type="button"
            class="rounded-xl border border-base-700 bg-base-900 px-4 py-3 text-sm text-base-200 hover:text-white hover:border-accent-300"
            hidden
          >
            Retry lock
          </button>
        </div>

        <p id="awake-client-metadata" class="mt-4 text-xs text-base-500" aria-live="polite"></p>

        <div class="mt-4 border-t border-base-700 pt-3">
          <button
            id="awake-settings-toggle"
            type="button"
            class="rounded-lg border border-base-700 bg-base-900 px-3 py-2 text-xs uppercase tracking-wider text-base-300 hover:text-white hover:border-accent-300"
            aria-expanded="false"
            aria-controls="awake-settings-drawer"
          >
            Settings
          </button>
        </div>
      </div>

      <div id="awake-settings-drawer" class="awake-settings-drawer" data-open="false" aria-hidden="true">
        <div class="space-y-4 border-t border-base-700 pt-4">
          <div class="rounded-xl border border-base-700 bg-base-900/70 p-4">
            <p class="awake-kicker text-xs uppercase tracking-wider text-base-400">Preferences</p>
            <label class="mt-3 flex items-center justify-between gap-3 text-sm text-base-300">
              <span class="awake-label">10-second beep alert</span>
              <input
                id="awake-beep-alert-toggle"
                type="checkbox"
                class="h-4 w-4 rounded border-base-600 bg-base-900 text-accent-400 focus:ring-accent-300"
              />
            </label>
          </div>

          <div class="rounded-xl border border-base-700 bg-base-900/70 p-4">
            <p class="awake-kicker text-xs uppercase tracking-wider text-base-400">Profiles</p>
            <div class="mt-3 space-y-4">
              <ProfileQuickLaunch />
              <ProfileManager />
            </div>
          </div>

          <ShortcutHints />

          <StatusRail />

          <CapabilityBanner />
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { detectWakeClientInfo } from "../../lib/clientInfo";
  import { playSingleBeep } from "../../lib/wakeAlerts";
  import {
    calculateTimerProgress,
    PRESET_MINUTES,
    formatDurationMs,
    normalizeCustomMinutes,
  } from "../../lib/wakeSession";
  import { MAX_PROFILES, createWakeProfileService } from "../../lib/wakeProfiles";
  import { retainWakeSessionEngine } from "../../lib/wakeSessionRuntime";
  import { createWakeShortcutController } from "../../lib/wakeShortcuts";
  import { createWakeUiPreferenceService } from "../../lib/wakeUiPreferences";

  const SELECTED_PROFILE_STORAGE_KEY = "awakemode:selected-profile-id";

  const formatEventLabel = (eventType) => {
    const labels = {
      started: "Session started",
      paused: "Session paused",
      resumed: "Session resumed",
      stopped: "Session stopped",
      acquired: "Wake lock acquired",
      released: "Wake lock released",
      blocked: "Wake lock blocked",
      reacquire_attempt: "Reacquire attempt",
      reacquire_success: "Reacquire success",
      reacquire_failed: "Reacquire failed",
      timer_completed: "Timer completed",
    };

    return labels[eventType] ?? eventType;
  };

  const setupAwakeControlPanel = () => {
    const panel = document.getElementById("awake-control-panel");
    if (!panel) {
      return;
    }

    const capabilityBanner = panel.querySelector("#awake-capability-banner");
    const statusBadge = panel.querySelector("#awake-status-badge");
    const statusDetail = panel.querySelector("#awake-status-detail");
    const timerRemaining = panel.querySelector("#awake-timer-remaining");
    const timerVisual = panel.querySelector("#awake-timer-visual");
    const timerProgressBar = panel.querySelector("#awake-timer-progress-bar");
    const timerCountdown = panel.querySelector("#awake-timer-countdown");
    const timerControls = panel.querySelector("#awake-timer-controls");
    const primaryAction = panel.querySelector("#awake-primary-action");
    const retryAction = panel.querySelector("#awake-retry-action");
    const modeInputs = panel.querySelectorAll('input[name="awake-session-mode"]');
    const presetButtons = panel.querySelectorAll("[data-timer-preset]");
    const customMinutesInput = panel.querySelector("#awake-custom-minutes");
    const settingsToggle = panel.querySelector("#awake-settings-toggle");
    const settingsDrawer = panel.querySelector("#awake-settings-drawer");
    const clientMetadata = panel.querySelector("#awake-client-metadata");
    const beepAlertToggle = panel.querySelector("#awake-beep-alert-toggle");

    const platformHint = panel.querySelector("#awake-platform-hint");
    const macHint = panel.querySelector("#awake-mac-hint");
    const windowsHint = panel.querySelector("#awake-windows-hint");
    const otherHint = panel.querySelector("#awake-other-hint");

    const quickLaunchContainer = panel.querySelector("#awake-quick-launch");
    const profileSelectControl = panel.querySelector("#awake-profile-select-control");
    const profileSelect = panel.querySelector("#awake-profile-select");
    const profileSelectTrigger = panel.querySelector("#awake-profile-select-trigger");
    const profileSelectLabel = panel.querySelector("#awake-profile-select-label");
    const profileSelectListbox = panel.querySelector("#awake-profile-select-listbox");
    const profileNewShortcut = panel.querySelector("#awake-profile-new-shortcut");
    const profileNameField = panel.querySelector("#awake-profile-name-field");
    const profileNameInput = panel.querySelector("#awake-profile-name");
    const profileModeSelect = panel.querySelector("#awake-profile-mode");
    const profileDurationInput = panel.querySelector("#awake-profile-duration");
    const profileCount = panel.querySelector("#awake-profile-count");
    const profileSave = panel.querySelector("#awake-profile-save");
    const profileDelete = panel.querySelector("#awake-profile-delete");
    const profileSetDefault = panel.querySelector("#awake-profile-set-default");
    const profileFeedback = panel.querySelector("#awake-profile-feedback");

    const lockLossCount = panel.querySelector("#awake-lock-loss-count");
    const eventLog = panel.querySelector("#awake-event-log");

    if (
      !capabilityBanner ||
      !statusBadge ||
      !statusDetail ||
      !timerRemaining ||
      !timerVisual ||
      !timerProgressBar ||
      !timerCountdown ||
      !timerControls ||
      !primaryAction ||
      !retryAction ||
      !modeInputs.length ||
      !presetButtons.length ||
      !customMinutesInput ||
      !settingsToggle ||
      !settingsDrawer ||
      !clientMetadata ||
      !beepAlertToggle ||
      !platformHint ||
      !macHint ||
      !windowsHint ||
      !otherHint ||
      !quickLaunchContainer ||
      !profileSelectControl ||
      !profileSelect ||
      !profileSelectTrigger ||
      !profileSelectLabel ||
      !profileSelectListbox ||
      !profileNewShortcut ||
      !profileNameField ||
      !profileNameInput ||
      !profileModeSelect ||
      !profileDurationInput ||
      !profileCount ||
      !profileSave ||
      !profileDelete ||
      !profileSetDefault ||
      !profileFeedback ||
      !lockLossCount ||
      !eventLog
    ) {
      return;
    }

    const sessionLease = retainWakeSessionEngine();
    const engine = sessionLease.controller;
    const profileService = createWakeProfileService();
    const uiPreferenceService = createWakeUiPreferenceService({
      defaultCustomMinutes: PRESET_MINUTES.includes(30) ? 30 : PRESET_MINUTES[0],
    });

    const nav = navigator;
    const navWithUserAgentData = nav;
    const userAgentDataBrands = Array.isArray(navWithUserAgentData.userAgentData?.brands)
      ? navWithUserAgentData.userAgentData.brands
      : null;

    const clientInfo = detectWakeClientInfo({
      userAgent: nav.userAgent,
      platform: nav.platform,
      userAgentDataBrands,
    });

    let uiPreferences = uiPreferenceService.read();
    let settingsOpen = uiPreferences.settingsOpen;
    let persistedMode = uiPreferences.mode;
    let persistedCustomMinutes = uiPreferences.customMinutes;
    let persistedBeepAlerts = uiPreferences.beepAlerts;

    const writeUiPreferences = (patch) => {
      uiPreferences = uiPreferenceService.write(patch);
      settingsOpen = uiPreferences.settingsOpen;
      persistedMode = uiPreferences.mode;
      persistedCustomMinutes = uiPreferences.customMinutes;
      persistedBeepAlerts = uiPreferences.beepAlerts;
      return uiPreferences;
    };

    const persistModePreference = (mode) => {
      if (persistedMode === mode) {
        return;
      }

      writeUiPreferences({ mode });
    };

    const persistCustomMinutesPreference = (minutes) => {
      const normalized = normalizeCustomMinutes(minutes);
      if (normalized === null || persistedCustomMinutes === normalized) {
        return;
      }

      writeUiPreferences({ customMinutes: normalized });
    };

    const persistBeepAlertPreference = (enabled) => {
      if (persistedBeepAlerts === enabled) {
        return;
      }

      writeUiPreferences({ beepAlerts: enabled });
    };

    const maybePlayTimerStartChirp = () => {
      if (!persistedBeepAlerts) {
        return;
      }

      const state = engine.getState();
      if (!state.intent || state.mode !== "timer") {
        return;
      }

      void playSingleBeep();
    };

    const defaultPreset = PRESET_MINUTES.includes(30) ? 30 : PRESET_MINUTES[0];
    const inferSessionStartTimestamp = (state, nowTimestamp) => {
      if (!state.intent) {
        return null;
      }

      if (
        state.mode === "timer" &&
        typeof state.timerDurationMs === "number" &&
        Number.isFinite(state.timerDurationMs) &&
        typeof state.remainingMs === "number" &&
        Number.isFinite(state.remainingMs)
      ) {
        const elapsedMs = Math.max(0, state.timerDurationMs - state.remainingMs);
        return Math.max(0, nowTimestamp - elapsedMs);
      }

      return nowTimestamp;
    };

    let selectedPreset = PRESET_MINUTES.includes(uiPreferences.customMinutes)
      ? uiPreferences.customMinutes
      : defaultPreset;
    let profiles = [];
    let quickLaunchProfiles = [];
    let selectedProfileId = (() => {
      try {
        const storedValue = window.localStorage.getItem(SELECTED_PROFILE_STORAGE_KEY);
        return storedValue && storedValue.trim() ? storedValue : null;
      } catch {
        return null;
      }
    })();
    let eventHistory = [];
    let currentSessionStartTimestamp = inferSessionStartTimestamp(engine.getState(), Date.now());
    let lockLosses = 0;
    let profileSelectOpen = false;
    let profileSelectActiveIndex = 0;
    let profileSelectOptions = [];
    let profilePulseTimeoutHandle = null;

    const NEW_PROFILE_VALUE = "__new";

    const setSelectedProfileId = (profileId) => {
      selectedProfileId = profileId;

      try {
        if (profileId) {
          window.localStorage.setItem(SELECTED_PROFILE_STORAGE_KEY, profileId);
        } else {
          window.localStorage.removeItem(SELECTED_PROFILE_STORAGE_KEY);
        }
      } catch {
        // Ignore localStorage failures (private mode, quota, etc.).
      }
    };

    const setSettingsOpen = (isOpen, { persist = true } = {}) => {
      settingsOpen = isOpen;
      settingsDrawer.setAttribute("data-open", String(isOpen));
      settingsDrawer.setAttribute("aria-hidden", String(!isOpen));
      settingsToggle.setAttribute("aria-expanded", String(isOpen));
      settingsToggle.textContent = isOpen ? "Hide settings" : "Settings";

      if (persist && uiPreferences.settingsOpen !== isOpen) {
        writeUiPreferences({ settingsOpen: isOpen });
      }
    };

    const setProfileFeedback = (message, tone = "neutral") => {
      profileFeedback.textContent = message;
      profileFeedback.setAttribute("data-tone", tone);
    };

    const setProfileSelectOpen = (isOpen) => {
      profileSelectOpen = isOpen;
      profileSelectTrigger.setAttribute("aria-expanded", String(isOpen));
      profileSelectListbox.hidden = !isOpen;
      profileSelectListbox.classList.toggle("hidden", !isOpen);
    };

    const setProfileActiveIndex = (index) => {
      if (profileSelectOptions.length === 0) {
        profileSelectActiveIndex = 0;
        profileSelectTrigger.removeAttribute("aria-activedescendant");
        return;
      }

      profileSelectActiveIndex = Math.max(0, Math.min(index, profileSelectOptions.length - 1));
      const active = profileSelectOptions[profileSelectActiveIndex];
      if (!active) {
        profileSelectTrigger.removeAttribute("aria-activedescendant");
        return;
      }

      profileSelectTrigger.setAttribute("aria-activedescendant", active.id);
      const activeElement = profileSelectListbox.querySelector(`#${active.id}`);
      activeElement?.scrollIntoView({ block: "nearest" });
    };

    const syncProfileSelectVisualState = () => {
      profileSelectOptions.forEach((option, index) => {
        const optionElement = profileSelectListbox.querySelector(`#${option.id}`);
        if (!optionElement) {
          return;
        }

        const isSelected = option.value === profileSelect.value;
        const isActive = index === profileSelectActiveIndex;
        optionElement.setAttribute("aria-selected", String(isSelected));
        optionElement.setAttribute("data-selected", String(isSelected));
        optionElement.setAttribute("data-active", String(isActive));
      });
    };

    const closeProfileSelect = ({ focusTrigger = false } = {}) => {
      setProfileSelectOpen(false);
      syncProfileSelectVisualState();
      if (focusTrigger) {
        profileSelectTrigger.focus();
      }
    };

    const openProfileSelect = () => {
      setProfileSelectOpen(true);
      const selectedIndex = profileSelectOptions.findIndex(
        (option) => option.value === profileSelect.value,
      );
      setProfileActiveIndex(selectedIndex >= 0 ? selectedIndex : 0);
      syncProfileSelectVisualState();
      profileSelectListbox.focus();
    };

    const setProfileSelectValue = (value, { emitChange = true } = {}) => {
      profileSelect.value = value;
      const matchedOption = profileSelectOptions.find((option) => option.value === value);
      profileSelectLabel.textContent = matchedOption?.label ?? "Create new profile";

      const selectedIndex = profileSelectOptions.findIndex((option) => option.value === value);
      setProfileActiveIndex(selectedIndex >= 0 ? selectedIndex : 0);
      syncProfileSelectVisualState();

      if (emitChange) {
        profileSelect.dispatchEvent(new Event("change", { bubbles: true }));
      }
    };

    const pulseProfileNameField = () => {
      profileNameField.classList.remove("awake-profile-input-pulse");
      void profileNameField.offsetWidth;
      profileNameField.classList.add("awake-profile-input-pulse");

      if (profilePulseTimeoutHandle) {
        window.clearTimeout(profilePulseTimeoutHandle);
      }

      profilePulseTimeoutHandle = window.setTimeout(() => {
        profileNameField.classList.remove("awake-profile-input-pulse");
        profilePulseTimeoutHandle = null;
      }, 2000);
    };

    const getSelectedMode = () => {
      const selected = [...modeInputs].find((input) => input.checked);
      return selected?.value === "timer" ? "timer" : "indefinite";
    };

    const clearPresetSelection = () => {
      presetButtons.forEach((button) => button.setAttribute("aria-pressed", "false"));
    };

    const setSelectedPreset = (minutes) => {
      selectedPreset = minutes;
      presetButtons.forEach((button) => {
        const value = Number(button.getAttribute("data-timer-preset"));
        button.setAttribute("aria-pressed", String(value === minutes));
      });
    };

    const renderModeState = () => {
      const isTimer = getSelectedMode() === "timer";
      timerControls.hidden = !isTimer;
    };

    const setProfileDurationEnabled = (mode) => {
      profileDurationInput.disabled = mode !== "timer";
      if (mode !== "timer") {
        profileDurationInput.value = "";
      }
    };

    const renderClientMetadata = (state) => {
      const compatibility = state.supportStatus === "unsupported" ? "Not compatible" : "Compatible";
      clientMetadata.textContent = `${clientInfo.browser} on ${clientInfo.machine} | ${compatibility}`;
      clientMetadata.setAttribute(
        "data-compatibility",
        state.supportStatus === "unsupported" ? "unsupported" : "supported",
      );
    };

    const applyProfileToSessionControls = (profile) => {
      if (!profile) {
        return;
      }

      modeInputs.forEach((input) => {
        input.checked = input.value === profile.mode;
      });
      persistModePreference(profile.mode);

      if (profile.mode === "timer") {
        const duration = profile.durationMinutes ?? defaultPreset;
        customMinutesInput.value = String(duration);
        persistCustomMinutesPreference(duration);

        if (PRESET_MINUTES.includes(duration)) {
          setSelectedPreset(duration);
        } else {
          clearPresetSelection();
        }
      }

      renderModeState();
    };

    const applyProfileToEditor = (profile) => {
      if (!profile) {
        profileNameInput.value = "";
        profileModeSelect.value = "timer";
        profileDurationInput.value = String(defaultPreset);
        setProfileDurationEnabled("timer");
        return;
      }

      profileNameInput.value = profile.name;
      profileModeSelect.value = profile.mode;
      profileDurationInput.value =
        profile.mode === "timer" && profile.durationMinutes !== null
          ? String(profile.durationMinutes)
          : "";
      setProfileDurationEnabled(profile.mode);
    };

    const renderQuickLaunch = () => {
      quickLaunchContainer.innerHTML = "";

      if (quickLaunchProfiles.length === 0) {
        const empty = document.createElement("p");
        empty.className = "text-sm text-base-400";
        empty.textContent = "No launch profiles available.";
        quickLaunchContainer.append(empty);
        return;
      }

      quickLaunchProfiles.forEach((profile, index) => {
        const button = document.createElement("button");
        button.type = "button";
        button.className =
          "awake-quick-launch rounded-lg border border-base-700 bg-base-900 px-3 py-2 text-sm text-base-200 text-left hover:text-white hover:border-accent-300";
        button.dataset.profileId = profile.id;
        button.innerHTML = `<span class="text-xs text-base-500 mr-2">${index + 1}</span>${profile.name}`;

        button.addEventListener("click", async () => {
          await launchProfile(profile);
        });

        quickLaunchContainer.append(button);
      });
    };

    const renderProfileOptions = () => {
      profileSelectListbox.innerHTML = "";
      profileSelectOptions = [];

      const addProfileSelectOption = (value, label) => {
        const safeValue =
          value === NEW_PROFILE_VALUE ? "new" : value.replace(/[^a-zA-Z0-9_-]/g, "_");
        const id = `awake-profile-select-option-${safeValue}`;
        profileSelectOptions.push({ value, label, id });

        const optionElement = document.createElement("li");
        optionElement.id = id;
        optionElement.setAttribute("role", "option");
        optionElement.setAttribute("aria-selected", "false");
        optionElement.setAttribute("data-selected", "false");
        optionElement.setAttribute("data-active", "false");
        optionElement.className =
          "awake-profile-list-option rounded-md px-2.5 py-2 text-sm text-base-200";
        optionElement.textContent = label;

        optionElement.addEventListener("click", () => {
          setProfileSelectValue(value);
          closeProfileSelect({ focusTrigger: true });
        });

        profileSelectListbox.append(optionElement);
      };

      addProfileSelectOption(NEW_PROFILE_VALUE, "Create new profile");
      profiles.forEach((profile) => {
        addProfileSelectOption(
          profile.id,
          `${profile.name}${profile.isDefault ? " (default)" : ""}`,
        );
      });

      const selectedExists = profiles.some((profile) => profile.id === selectedProfileId);
      if (!selectedExists) {
        setSelectedProfileId(profiles.find((profile) => profile.isDefault)?.id ?? null);
      }

      setProfileSelectValue(selectedProfileId ?? NEW_PROFILE_VALUE, {
        emitChange: false,
      });

      const selectedProfile = profiles.find((profile) => profile.id === selectedProfileId) ?? null;
      applyProfileToEditor(selectedProfile);

      profileDelete.disabled = !selectedProfile;
      profileSetDefault.disabled = !selectedProfile || selectedProfile.isDefault;
    };

    const renderProfiles = ({ applyToSession = false } = {}) => {
      profiles = profileService.listProfiles();
      quickLaunchProfiles = profiles.slice(0, 3);

      profileCount.textContent = `${profiles.length}/${MAX_PROFILES}`;
      renderQuickLaunch();
      renderProfileOptions();

      if (applyToSession) {
        const selectedProfile = profiles.find((profile) => profile.id === selectedProfileId) ?? null;
        applyProfileToSessionControls(selectedProfile);
      }
    };

    const getTimerDurationMs = () => {
      const rawValue = customMinutesInput.value.trim();
      if (!rawValue) {
        customMinutesInput.setCustomValidity("");
        return selectedPreset * 60_000;
      }

      const normalized = normalizeCustomMinutes(rawValue);
      if (normalized === null) {
        customMinutesInput.setCustomValidity("Enter a value between 1 and 1440 minutes.");
        customMinutesInput.reportValidity();
        return null;
      }

      customMinutesInput.setCustomValidity("");
      return normalized * 60_000;
    };

    const getProfileInput = () => {
      const mode = profileModeSelect.value === "timer" ? "timer" : "indefinite";
      const durationMinutes =
        mode === "timer" ? normalizeCustomMinutes(profileDurationInput.value.trim()) : null;

      if (mode === "timer" && durationMinutes === null) {
        throw new Error("Duration must be between 1 and 1440 minutes.");
      }

      return {
        name: profileNameInput.value,
        mode,
        durationMinutes,
      };
    };

    const applyBadgeStatus = (label) => {
      statusBadge.textContent = label;
      statusBadge.setAttribute("data-status", label.toLowerCase());
    };

    const applyFallbackHints = (shouldShow, platform) => {
      platformHint.hidden = !shouldShow;
      macHint.hidden = platform !== "mac";
      windowsHint.hidden = platform !== "windows";
      otherHint.hidden = platform !== "other";
    };

    const renderEventLog = () => {
      eventLog.innerHTML = "";

      if (eventHistory.length === 0) {
        const empty = document.createElement("tr");
        const emptyCell = document.createElement("td");
        emptyCell.colSpan = 4;
        emptyCell.className = "py-2 text-base-500";
        emptyCell.textContent = "No events yet.";
        empty.append(emptyCell);
        eventLog.append(empty);
        return;
      }

      eventHistory.forEach((entry) => {
        const line = document.createElement("tr");

        const label = document.createElement("td");
        label.className = "py-1.5 pr-5 align-top";
        label.textContent = formatEventLabel(entry.type);

        const timestamp = document.createElement("td");
        timestamp.className = "py-1.5 pr-5 align-top text-base-500 tabular-nums whitespace-nowrap";
        timestamp.textContent = new Date(entry.timestamp).toLocaleTimeString([], {
          hour12: false,
          hour: "2-digit",
          minute: "2-digit",
          second: "2-digit",
        });

        const duration = document.createElement("td");
        duration.className = "py-1.5 pr-5 align-top text-base-500 tabular-nums whitespace-nowrap";
        duration.textContent =
          typeof entry.runDurationMs === "number" && Number.isFinite(entry.runDurationMs)
            ? formatDurationMs(entry.runDurationMs)
            : "--";

        const detail = document.createElement("td");
        detail.className = "py-1.5 align-top text-base-500 whitespace-nowrap truncate";
        detail.title = entry.detail ?? "--";
        detail.textContent = entry.detail ?? "--";

        line.append(label, timestamp, duration, detail);

        eventLog.append(line);
      });
    };

    const renderState = (state) => {
      modeInputs.forEach((input) => {
        input.checked = input.value === state.mode;
      });
      persistModePreference(state.mode);

      capabilityBanner.hidden = state.supportStatus !== "unsupported";
      renderModeState();
      renderClientMetadata(state);

      if (state.mode === "timer" && state.intent && state.remainingMs !== null) {
        const progress = calculateTimerProgress(state.remainingMs, state.timerDurationMs);

        timerVisual.hidden = false;
        timerProgressBar.style.transform = `scaleX(${progress ?? 1})`;
        timerCountdown.textContent = `${state.isPaused ? "Paused at " : "Time left: "}${formatDurationMs(state.remainingMs)}`;

        timerRemaining.hidden = false;
        timerRemaining.textContent = `Time left: ${formatDurationMs(state.remainingMs)}`;
      } else {
        timerVisual.hidden = true;
        timerProgressBar.style.transform = "scaleX(1)";
        timerCountdown.textContent = "";
        timerRemaining.hidden = true;
        timerRemaining.textContent = "";
      }

      const showFallback =
        state.supportStatus === "unsupported" ||
        (state.supportStatus === "blocked" && state.intent);
      applyFallbackHints(showFallback, state.platform);

      if (state.supportStatus === "unsupported") {
        applyBadgeStatus("Unsupported");
        statusDetail.textContent =
          "Screen Wake Lock is unavailable in this browser. Use Chromium for AwakeMode sessions.";
      } else if (state.isPaused && state.mode === "timer") {
        applyBadgeStatus("Paused");
        statusDetail.textContent = "Timer is paused. Resume to continue countdown.";
      } else if (state.hasActiveLock) {
        applyBadgeStatus("Active");
        statusDetail.textContent =
          state.mode === "timer"
            ? "Wake lock is active and the countdown is running."
            : "Wake lock is active until you stop this session.";
      } else if (state.supportStatus === "blocked" && state.intent) {
        applyBadgeStatus("Blocked");
        statusDetail.textContent = state.lastError
          ? `Wake lock request blocked: ${state.lastError}`
          : "Wake lock request blocked by browser or system policy.";
      } else {
        applyBadgeStatus("Released");
        statusDetail.textContent =
          state.mode === "timer" && state.remainingMs === 0
            ? "Timer completed and wake lock was released."
            : "No active wake lock session.";
      }

      primaryAction.textContent = state.intent
        ? state.isPaused
          ? "Resume session"
          : "Stop session"
        : "Start session";
      primaryAction.disabled = state.supportStatus === "unsupported" && !state.intent;

      retryAction.hidden = !(state.supportStatus === "blocked" && state.intent);
      retryAction.disabled = state.supportStatus === "unsupported";

      lockLossCount.textContent = String(lockLosses);
    };

    const startFromControls = async () => {
      const mode = getSelectedMode();
      persistModePreference(mode);

      if (mode === "timer") {
        const durationMs = getTimerDurationMs();
        if (durationMs === null) {
          return;
        }

        persistCustomMinutesPreference(durationMs / 60_000);
        await engine.start("timer", durationMs);
        maybePlayTimerStartChirp();
        return;
      }

      await engine.start("indefinite");
    };

    const toggleStartStop = async () => {
      const state = engine.getState();
      if (state.intent) {
        if (state.isPaused && state.mode === "timer") {
          await engine.resume();
          return;
        }

        await engine.stop();
        return;
      }

      await startFromControls();
    };

    const toggleMode = () => {
      const nextMode = getSelectedMode() === "timer" ? "indefinite" : "timer";
      modeInputs.forEach((input) => {
        input.checked = input.value === nextMode;
      });
      persistModePreference(nextMode);

      if (nextMode === "timer" && !customMinutesInput.value.trim()) {
        customMinutesInput.value = String(selectedPreset);
      }

      renderModeState();
    };

    const launchProfile = async (profile) => {
      setSelectedProfileId(profile.id);
      setProfileSelectValue(profile.id, { emitChange: false });
      applyProfileToEditor(profile);
      applyProfileToSessionControls(profile);

      const currentState = engine.getState();
      if (currentState.intent) {
        await engine.stop();
      }

      if (profile.mode === "timer") {
        const durationMinutes = normalizeCustomMinutes(profile.durationMinutes);
        if (durationMinutes === null) {
          setProfileFeedback("Profile timer duration is invalid.", "error");
          return;
        }

        await engine.start("timer", durationMinutes * 60_000);
        maybePlayTimerStartChirp();
      } else {
        await engine.start("indefinite");
      }

      setProfileFeedback(`Launched ${profile.name}.`, "success");
    };

    modeInputs.forEach((input) => {
      input.checked = input.value === uiPreferences.mode;
    });

    if (PRESET_MINUTES.includes(uiPreferences.customMinutes)) {
      setSelectedPreset(uiPreferences.customMinutes);
      customMinutesInput.value = String(uiPreferences.customMinutes);
    } else {
      clearPresetSelection();
      customMinutesInput.value = String(uiPreferences.customMinutes);
    }

    renderProfiles({ applyToSession: false });
    renderEventLog();
    renderModeState();
    setProfileSelectOpen(false);
    setSettingsOpen(settingsOpen, { persist: false });
    beepAlertToggle.checked = uiPreferences.beepAlerts;

    presetButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const presetValue = Number(button.getAttribute("data-timer-preset"));
        if (!Number.isFinite(presetValue)) {
          return;
        }

        setSelectedPreset(presetValue);
        customMinutesInput.value = String(presetValue);
        persistCustomMinutesPreference(presetValue);
      });
    });

    customMinutesInput.addEventListener("input", () => {
      const normalized = normalizeCustomMinutes(customMinutesInput.value.trim());
      if (normalized !== null && PRESET_MINUTES.includes(normalized)) {
        setSelectedPreset(normalized);
      } else {
        clearPresetSelection();
      }

      if (normalized !== null) {
        persistCustomMinutesPreference(normalized);
      }
    });

    modeInputs.forEach((input) => {
      input.addEventListener("change", () => {
        renderModeState();
        persistModePreference(getSelectedMode());
      });
    });

    settingsToggle.addEventListener("click", () => {
      setSettingsOpen(!settingsOpen);
    });

    beepAlertToggle.addEventListener("change", () => {
      persistBeepAlertPreference(beepAlertToggle.checked);
    });

    profileSelectTrigger.addEventListener("click", () => {
      if (profileSelectOpen) {
        closeProfileSelect({ focusTrigger: true });
        return;
      }

      openProfileSelect();
    });

    profileSelectTrigger.addEventListener("keydown", (event) => {
      const { key } = event;
      const moveActive = (delta) => {
        if (profileSelectOptions.length === 0) {
          return;
        }

        const nextIndex =
          (profileSelectActiveIndex + delta + profileSelectOptions.length) %
          profileSelectOptions.length;
        setProfileActiveIndex(nextIndex);
        syncProfileSelectVisualState();
      };

      if (key === "ArrowDown") {
        event.preventDefault();
        if (!profileSelectOpen) {
          openProfileSelect();
          moveActive(1);
        } else {
          moveActive(1);
        }
        return;
      }

      if (key === "ArrowUp") {
        event.preventDefault();
        if (!profileSelectOpen) {
          openProfileSelect();
          moveActive(-1);
        } else {
          moveActive(-1);
        }
        return;
      }

      if (key === "Enter" || key === " ") {
        event.preventDefault();
        if (!profileSelectOpen) {
          openProfileSelect();
          return;
        }

        const activeOption = profileSelectOptions[profileSelectActiveIndex];
        if (activeOption) {
          setProfileSelectValue(activeOption.value);
        }
        closeProfileSelect({ focusTrigger: true });
        return;
      }

      if (key === "Escape" && profileSelectOpen) {
        event.preventDefault();
        closeProfileSelect({ focusTrigger: true });
      }
    });

    profileSelectListbox.addEventListener("keydown", (event) => {
      const { key } = event;
      const moveActive = (delta) => {
        if (profileSelectOptions.length === 0) {
          return;
        }

        const nextIndex =
          (profileSelectActiveIndex + delta + profileSelectOptions.length) %
          profileSelectOptions.length;
        setProfileActiveIndex(nextIndex);
        syncProfileSelectVisualState();
      };

      if (key === "ArrowDown") {
        event.preventDefault();
        moveActive(1);
        return;
      }

      if (key === "ArrowUp") {
        event.preventDefault();
        moveActive(-1);
        return;
      }

      if (key === "Enter" || key === " ") {
        event.preventDefault();
        const activeOption = profileSelectOptions[profileSelectActiveIndex];
        if (activeOption) {
          setProfileSelectValue(activeOption.value);
        }
        closeProfileSelect({ focusTrigger: true });
        return;
      }

      if (key === "Escape") {
        event.preventDefault();
        closeProfileSelect({ focusTrigger: true });
        return;
      }

      if (key === "Tab") {
        closeProfileSelect();
      }
    });

    profileSelectControl.addEventListener("focusout", (event) => {
      if (profileSelectControl.contains(event.relatedTarget)) {
        return;
      }

      closeProfileSelect();
    });

    document.addEventListener("pointerdown", (event) => {
      if (!profileSelectOpen) {
        return;
      }

      if (profileSelectControl.contains(event.target)) {
        return;
      }

      closeProfileSelect();
    });

    profileNewShortcut.addEventListener("click", () => {
      setSelectedProfileId(null);
      setProfileSelectValue(NEW_PROFILE_VALUE);
      closeProfileSelect();
      profileNameInput.focus();
      pulseProfileNameField();
    });

    primaryAction.addEventListener("click", async () => {
      await toggleStartStop();
    });

    retryAction.addEventListener("click", async () => {
      await engine.retry();
    });

    profileModeSelect.addEventListener("change", () => {
      const mode = profileModeSelect.value === "timer" ? "timer" : "indefinite";
      setProfileDurationEnabled(mode);
    });

    profileSelect.addEventListener("change", () => {
      closeProfileSelect();
      const selectedId = profileSelect.value;
      if (selectedId === NEW_PROFILE_VALUE) {
        setSelectedProfileId(null);
        applyProfileToEditor(null);
        profileDelete.disabled = true;
        profileSetDefault.disabled = true;
        return;
      }

      setSelectedProfileId(selectedId);
      const profile = profiles.find((item) => item.id === selectedId) ?? null;
      applyProfileToEditor(profile);
      applyProfileToSessionControls(profile);
      profileDelete.disabled = !profile;
      profileSetDefault.disabled = !profile || profile.isDefault;
    });

    profileSave.addEventListener("click", () => {
      try {
        const profileInput = getProfileInput();

        if (!selectedProfileId) {
          const created = profileService.createProfile(profileInput);
          setSelectedProfileId(created.id);
          setProfileFeedback(`Created profile ${created.name}.`, "success");
        } else {
          const updated = profileService.updateProfile(selectedProfileId, profileInput);
          setProfileFeedback(`Updated profile ${updated.name}.`, "success");
        }

        renderProfiles({ applyToSession: false });
      } catch (error) {
        const message = error instanceof Error ? error.message : "Unable to save profile.";
        setProfileFeedback(message, "error");
      }
    });

    profileDelete.addEventListener("click", () => {
      if (!selectedProfileId) {
        return;
      }

      try {
        profileService.deleteProfile(selectedProfileId);
        setSelectedProfileId(null);
        setProfileFeedback("Profile deleted.", "success");
        renderProfiles({ applyToSession: false });
      } catch (error) {
        const message = error instanceof Error ? error.message : "Unable to delete profile.";
        setProfileFeedback(message, "error");
      }
    });

    profileSetDefault.addEventListener("click", () => {
      if (!selectedProfileId) {
        return;
      }

      try {
        const defaultProfile = profileService.setDefaultProfile(selectedProfileId);
        setProfileFeedback(`${defaultProfile.name} is now default.`, "success");
        renderProfiles({ applyToSession: false });
      } catch (error) {
        const message = error instanceof Error ? error.message : "Unable to set default profile.";
        setProfileFeedback(message, "error");
      }
    });

    const shortcuts = createWakeShortcutController({
      onToggleStartStop: () => {
        void toggleStartStop();
      },
      onToggleMode: () => {
        toggleMode();
      },
      onLaunchProfile: (index) => {
        const profile = quickLaunchProfiles[index];
        if (profile) {
          void launchProfile(profile);
        }
      },
      onRetry: () => {
        void engine.retry();
      },
    });

    const detachShortcuts = shortcuts.attach(window);

    const unsubscribeState = engine.subscribe((state) => {
      renderState(state);
    });

    const unsubscribeEvents = engine.subscribeEvents((event) => {
      if (event.type === "released" && event.detail === "sentinel") {
        lockLosses += 1;
      }

      if (event.type === "started") {
        currentSessionStartTimestamp = event.timestamp;
      }

      const shouldShowRunDuration =
        event.type === "stopped" || event.type === "released";
      const runDurationMs =
        shouldShowRunDuration && currentSessionStartTimestamp !== null
          ? Math.max(0, event.timestamp - currentSessionStartTimestamp)
          : null;
      const decoratedEvent = {
        ...event,
        runDurationMs,
      };

      eventHistory = [decoratedEvent, ...eventHistory].slice(0, 10);

      if (event.type === "released" && (event.detail === "manual" || event.detail === "timer")) {
        currentSessionStartTimestamp = null;
      }

      renderEventLog();
      lockLossCount.textContent = String(lockLosses);
    });

    renderState(engine.getState());

    window.addEventListener("pagehide", () => {
      detachShortcuts();
      unsubscribeState();
      unsubscribeEvents();
      sessionLease.release();
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupAwakeControlPanel, {
      once: true,
    });
  } else {
    setupAwakeControlPanel();
  }
</script>

